# Mini Social — copy to .env and fill values (no spaces around =)

PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/mini_social
# Atlas example:
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.xxx.mongodb.net/mini_social?retryWrites=true&w=majority

JWT_SECRET=use_a_long_random_string
JWT_EXPIRES=7d

# Optional CORS (single origin). Omit to allow any origin in development.
# CLIENT_ORIGIN=http://localhost:3000
